{
  "name": "portal-betina",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Portal de atividades neuropedagógicas para crianças com autismo, TDAH e outras necessidades cognitivas",  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext js,jsx --fix",
    "format": "prettier --write 'src/**/*.{js,jsx,css}'",
    "check-format": "prettier --check 'src/**/*.{js,jsx,css}'",
    "validate": "npm run lint && npm run check-format",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check-deps": "npm audit"
  },
  "dependencies": {
    "chart.js": "^4.4.9",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "framer-motion": "^10.16.4",
    "pg": "^8.16.0",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^18.2.0",
    "styled-components": "^6.1.0"
  },  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^4.0.3",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^8.10.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "jsdom": "^23.0.0",
    "prettier": "^3.0.3",
    "supertest": "^6.3.3",
    "vite": "^4.4.5",
    "vitest": "^0.34.6"
  }
}
