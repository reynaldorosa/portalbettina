# ======================================================
# PORTAL BETINA - CONFIGURAÇÕES DE AMBIENTE
# ======================================================
# ATENÇÃO: NÃO COMMITAR ESTE ARQUIVO EM REPOSITÓRIOS PÚBLICOS!
# Este arquivo contém configurações sensíveis e deve ser mantido localmente.
# Adicione '.env' ao .gitignore para evitar commits acidentais.
# Preencha os valores abaixo conforme o ambiente (desenvolvimento, produção, etc.).

# ======================================================
# CONFIGURAÇÕES DO BANCO DE DADOS
# ======================================================
DB_HOST=db
DB_PORT=5432
DB_USER=betina_user
DB_PASSWORD=betina_password
DB_NAME=betina_db

# URL completa do banco (opcional, gerada automaticamente no código)
# DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ======================================================
# CONFIGURAÇÕES DA API
# ======================================================
API_PORT=3000
API_HOST=api
JWT_SECRET=portal_betina_jwt_secret_key_super_secure_production_2025_@#$%
JWT_EXPIRES_IN=24h
BCRYPT_ROUNDS=12

# URLs da API para diferentes contextos
API_URL_INTERNAL=http://${API_HOST}:${API_PORT}/api
API_URL_EXTERNAL=http://localhost:${API_PORT}/api

# ======================================================
# CONFIGURAÇÕES DE SEGURANÇA E PERFORMANCE
# ======================================================
# Security Headers
SECURITY_HEADERS_ENABLED=true
CSP_ENABLED=true
HELMET_ENABLED=true

# Performance
COMPRESSION_LEVEL=6
STATIC_CACHE_MAX_AGE=86400

# Timeouts
SYNC_INTERVAL=30000
BATCH_SIZE=50
API_RETRY_ATTEMPTS=3

# ======================================================
# CONFIGURAÇÕES DO FRONTEND (VITE)
# ======================================================
VITE_API_URL=http://localhost:3000/api
VITE_API_HOST=localhost
VITE_API_PORT=3000
VITE_PRODUCTION_API_URL=http://localhost:3000/api
VITE_API_TIMEOUT=15000
VITE_API_RETRY_ATTEMPTS=3
VITE_SYNC_INTERVAL=30000
VITE_BATCH_SIZE=50
VITE_COMPRESSION_ENABLED=true
VITE_ENCRYPTION_ENABLED=true
VITE_ENABLE_CACHE=true
VITE_DEBUG_MODE=true
VITE_METRICS_INTERVAL=2000
VITE_LOG_LEVEL=debug
VITE_DB_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}
VITE_VERSION=2.0.0
VITE_ENVIRONMENT=development
VITE_API_KEY=dev-betina-api-key-2024

# ======================================================
# CONFIGURAÇÕES DE AMBIENTE
# ======================================================
NODE_ENV=development

# ======================================================
# CONFIGURAÇÕES DE REDE
# ======================================================
FRONTEND_PORT=5173
NGINX_PORT=80
DB_EXTERNAL_PORT=5432

# ======================================================
# CONFIGURAÇÕES DO NGINX
# ======================================================
NGINX_WORKER_CONNECTIONS=1024
NGINX_CLIENT_MAX_BODY_SIZE=50M
NGINX_KEEPALIVE_TIMEOUT=65
NGINX_PROXY_READ_TIMEOUT=60
NGINX_PROXY_CONNECT_TIMEOUT=60
NGINX_CACHE_EXPIRES_STATIC=1d
NGINX_CACHE_EXPIRES_MEDIA=1M

# ======================================================
# CONFIGURAÇÕES DE PROXY EXTERNO
# ======================================================
# SSL/TLS gerenciado pelo proxy manager externo
# Porta interna HTTP apenas

# ======================================================
# CONFIGURAÇÕES DE LOGS E DEBUG
# ======================================================
LOG_LEVEL=debug
DEBUG_MODE=true

# ======================================================
# CONFIGURAÇÕES DE CORS
# ======================================================
# Adicione aqui o domínio do seu proxy manager externo
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost,http://localhost:80,https://seu-dominio-do-proxy.com
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization,X-Requested-With,Accept,Origin,X-Environment,X-Client-Version

# ======================================================
# CONFIGURAÇÕES DE MONITORAMENTO E OBSERVABILIDADE
# ======================================================
HEALTH_CHECK_ENABLED=true
METRICS_COLLECTION_ENABLED=true
PERFORMANCE_MONITORING=true
ENABLE_METRICS=true
METRICS_INTERVAL=30000
LOG_PERFORMANCE=true

# APM e Telemetria
APM_ENABLED=false
TELEMETRY_ENDPOINT=
TELEMETRY_API_KEY=

# Alertas
ALERTS_ENABLED=false
ALERT_EMAIL=
ALERT_WEBHOOK=

# ======================================================
# CONFIGURAÇÕES DE AI
# ======================================================

VITE_DEEPSEEK_API_KEY=your_deepseek_api_key_here
VITE_DEEPSEEK_API_URL=https://api.deepseek.com/v1
VITE_DEEPSEEK_MODEL=deepseek-chat
VITE_DEEPSEEK_MAX_TOKENS=2048
VITE_DEEPSEEK_TEMPERATURE=0.7
VITE_DEEPSEEK_RETRY_DELAY_MS=2000
VITE_DEEPSEEK_FALLBACK_ENABLED=true

# ======================================================
# CONFIGURAÇÕES DE PERFORMANCE E OTIMIZAÇÃO
# ======================================================
# Compressão e Cache
ENABLE_COMPRESSION=true
ENABLE_CACHE=true
CACHE_TTL=3600
CACHE_MAX_SIZE=100MB
CACHE_STRATEGY=LRU

# Pool de Conexões Otimizado
CONNECTION_POOL_MIN=2
CONNECTION_POOL_MAX=15
CONNECTION_POOL_IDLE=3
CONNECTION_TIMEOUT=60000
IDLE_TIMEOUT=30000
CONNECTION_ACQUIRE_TIMEOUT=30000

# Rate Limiting Otimizado
RATE_LIMIT_WINDOW_MS=300000
RATE_LIMIT_MAX_REQUESTS=200
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=true
RATE_LIMIT_BURST=50
RATE_LIMIT_PER_USER=150

# Performance Tuning
API_RESPONSE_TIMEOUT=20000
DATABASE_QUERY_TIMEOUT=15000
FILE_UPLOAD_MAX_SIZE=50MB
REQUEST_BODY_LIMIT=10MB
KEEP_ALIVE_TIMEOUT=65000

# Background Jobs
JOB_QUEUE_ENABLED=true
JOB_CONCURRENCY=5
JOB_RETRY_ATTEMPTS=3
JOB_RETRY_DELAY=2000