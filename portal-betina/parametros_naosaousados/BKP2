  }

  calculateBehavioralAdjustments(sessionData) {
    const indicators = sessionData.indicators || {}
    return {
      structure: indicators.needsStructure ? 'increase' : 'maintain',
      reinforcement: indicators.motivationIssues ? 'increase' : 'maintain',
